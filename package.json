{
  "name": "omni-mall",
  "version": "0.1.0",
  "description": "Cross-merchant agentic shopping MCP server for the OmniMall PoC.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "test": "npm run build && node --import tsx --test test/core.test.ts",
    "test:e2e": "npm run build && tsx scripts/e2e-product-test.ts",
    "smoke": "tsx scripts/smoke-test.ts",
    "collect:amore": "tsx scripts/collect-amore-products.ts",
    "collect:merchants": "tsx scripts/collect-merchant-products.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.20.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
